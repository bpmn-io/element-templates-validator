{
  "name": "AWS S3 Connector",
  "id": "io.camunda.example.AwsS3Connector",
  "appliesTo": [ "bpmn:ServiceTask" ],
  "groups": [
    { "id": "auth", "label": "Authentication" }
  ],
  "properties": [
    {
      "id": "credential",
      "type": "Configuration",
      "label": "AWS credential",
      "group": "auth",
      "configurationTemplate": "io.camunda:aws-credential:1",
      "configurationTemplateVersion": 1,
      "binding": { "type": "zeebe:input", "name": "authentication" }
    }
  ],
  "configurationTemplates": [
    {
      "name": "AWS Credential",
      "id": "io.camunda:aws-credential:1",
      "kind": "CREDENTIAL",
      "version": 1,
      "properties": [
        {
          "label": "Access key",
          "type": "String",
          "secret": true,
          "binding": { "type": "property", "name": "accessKey" }
        }
      ]
    }
  ]
}
